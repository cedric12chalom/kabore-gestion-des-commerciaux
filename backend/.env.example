# GeoCommerce Pro - Configuration Environnement
# Copier ce fichier en .env et remplir les valeurs

# ==========================================
# DJANGO CORE
# ==========================================
DEBUG=True
SECRET_KEY=change-me-in-production-very-long-random-string-here
ALLOWED_HOSTS=localhost,127.0.0.1,.render.com,.vercel.app

# ==========================================
# DATABASE (PostgreSQL + PostGIS)
# ==========================================
DB_NAME=geocommerce_pro
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# ==========================================
# JWT AUTH
# ==========================================
ACCESS_TOKEN_LIFETIME=30          # minutes
REFRESH_TOKEN_LIFETIME=7          # days
ROTATE_REFRESH_TOKENS=True
BLACKLIST_AFTER_ROTATION=True

# ==========================================
# CORS (Frontend URLs)
# ==========================================
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://your-app.vercel.app

# ==========================================
# REDIS (Channels + Celery)
# ==========================================
REDIS_URL=redis://localhost:6379/0

# ==========================================
# EMAIL (Notifications)
# ==========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=geocommerce@yourcompany.com

# ==========================================
# GPS SETTINGS
# ==========================================
GPS_UPDATE_INTERVAL=30            # secondes
GPS_HISTORY_DAYS=90               # conservation historique
GPS_ALERT_ZONE_EXIT=True          # alertes sortie zone

# ==========================================
# RENDER / PRODUCTION
# ==========================================
RENDER_EXTERNAL_HOSTNAME=
DATABASE_URL=                     # Render fournit cette variable
